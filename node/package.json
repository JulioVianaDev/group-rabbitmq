{
  "name": "@juliovianadev/group-rabbitmq",
  "version": "1.0.0",
  "description": "A RabbitMQ library that adds **group-based ordering** and **per-worker concurrency limits** on top of standard AMQP queues.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand GroupStateStore.test.ts",
    "test:integration": "jest --runInBand --config jest.integration.config.cjs integration.test.ts",
    "example:worker:1": "cross-env WORKER_ID=worker-1 MAX_CONCURRENT_GROUPS=3 tsx example/worker.ts",
    "example:worker:2": "cross-env WORKER_ID=worker-2 MAX_CONCURRENT_GROUPS=3 tsx example/worker.ts",
    "example:worker:3": "cross-env WORKER_ID=worker-3 MAX_CONCURRENT_GROUPS=3 tsx example/worker.ts",
    "example:producer": "tsx example/producer.ts",
    "example:report": "tsx example/report.ts",
    "example:db-clean": "tsx example/clean-db.ts"
  },
  "keywords": [
    "rabbitmq",
    "amqp",
    "redis",
    "groups",
    "ordering",
    "message-queue"
  ],
  "author": "JulioVianaDev",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JulioVianaDev/group-rabbitmq.git",
    "directory": "node"
  },
  "bugs": {
    "url": "https://github.com/JulioVianaDev/group-rabbitmq/issues"
  },
  "homepage": "https://github.com/JulioVianaDev/group-rabbitmq/tree/main/node#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "amqplib": "^0.10.9",
    "ioredis": "^5.8.1",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.6.2",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
